# Copier ce fichier en ".env" et adapter les valeurs.
# IMPORTANT : ne jamais commiter le fichier ".env" (voir .gitignore).
# Toute variable VITE_* est injectée dans le bundle client (donc visible
# publiquement) : aucun secret ne doit être placé ici.

# URL de l'API backend (REST + Socket.IO)
VITE_API_URL=http://localhost:4000
