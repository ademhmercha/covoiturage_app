# Copier ce fichier en ".env" et adapter les valeurs.
# IMPORTANT : ne jamais commiter le fichier ".env" (voir .gitignore).
# En production, ces valeurs sont injectées via Azure Key Vault, jamais en dur.

# Environnement : development | test | production
NODE_ENV=development

# Port d'écoute de l'API
PORT=4000

# Origines autorisées pour CORS (liste blanche, séparées par des virgules)
# Jamais "*" — chaque domaine de production doit être listé explicitement.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Niveau de log winston : error | warn | info | http | debug
LOG_LEVEL=info

# Rate limiting global (toutes routes confondues)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Rate limiting login : 5 tentatives / 15 minutes (par IP et par compte)
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5

# Base de données (local : docker compose up -d postgres)
# Production : Azure Database for PostgreSQL Flexible Server, sslmode=require
DATABASE_URL=postgresql://wasel:wasel_dev_only@localhost:5432/wasel?schema=public

# Redis — sessions, blacklist de tokens révoqués, rate limiting (local : docker compose up -d redis)
REDIS_URL=redis://localhost:6379

# Clés JWT RS256, générées via `npm run generate:keys` (jamais commitées, voir .gitignore)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800

# Clé de chiffrement des champs sensibles : AES-256-GCM, 32 octets en base64,
# générée via `npm run generate:keys`.
FIELD_ENCRYPTION_KEY=

# Domaine du cookie de refresh token (laisser vide en local = host-only)
COOKIE_DOMAIN=
